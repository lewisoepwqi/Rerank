# Rerank 服务 Docker 部署变量示例（Linux GPU 服务器）。cp 成 .env 后按需改。

# 宿主机模型目录（挂到容器 /models，只读）。默认 ../models（与 docker/ 同级）。
MODELS_DIR=../models

# 相对 /models 的 GGUF 路径（容器内 = /models/${MODEL_FILE}）。
# 推荐 bge-reranker-v2-m3 的 Q8_0（约 640MB，判别力与 F16 基本无损）。
MODEL_FILE=bge-reranker-v2-m3/bge-reranker-v2-m3-Q8_0.gguf

# 宿主发布端口（容器内固定 8082）。8081 预留给日后嵌入服务，勿占。
RERANK_SERVER_PORT=8082

# 用哪张 GPU：与 Qwen 同卡 0（重排器小，共存无压力）。
GPU_DEVICE_ID=0

# 上卡层数：0.6B 可全量 offload。
N_GPU_LAYERS=99

# 上下文长度（query + 单文档）。bge-reranker-v2-m3 支持 8k。
CONTEXT_SIZE=8192
